<Window x:Class="ChatNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ChatNest.Views"
        Title="{Binding WindowTitle}"
        Icon="Resources/chatnest.ico"
        Width="520" Height="620"
        MinWidth="520" MinHeight="420"
        Topmost="{Binding IsTopmost}"
        Background="#F5F5F7"
        FontFamily="Yu Gothic UI, Meiryo UI, sans-serif">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0"
                Background="White"
                Padding="20,14,16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="8" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ChatNest"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1976D2"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="一時的な思考ログ"
                               FontSize="11"
                               Foreground="#9E9E9E"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}"
                            Content="開く"
                            ToolTip=".chatnestファイルを開く"
                            Margin="0,0,4,0"
                            Command="{Binding LoadCommand}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="上書き保存"
                            ToolTip="現在のファイルに保存（保存先がない場合はダイアログを表示）"
                            Margin="0,0,4,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="新規保存"
                            ToolTip="新しいファイルとして保存"
                            Margin="0,0,8,0"
                            Command="{Binding SaveAsCommand}"/>
                    <ToggleButton Style="{StaticResource TopmostToggle}"
                                  Content="最前面"
                                  IsChecked="{Binding IsTopmost, Mode=TwoWay}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  ToolTip="このウィンドウを常に最前面に表示する（ON/OFF）"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="終了処理"
                            ToolTip="コピー・新規チャット開始などの終了処理"
                            Click="FinishButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== WORKSPACE ========== -->
        <views:ChatNestWorkspaceView Grid.Row="1"
                                     DataContext="{Binding Workspace}"/>
    </Grid>
</Window>
