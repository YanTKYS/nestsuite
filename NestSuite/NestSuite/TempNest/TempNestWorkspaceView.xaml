<UserControl x:Class="NestSuite.TempNest.TempNestWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- SH-40: 「続きから」recentリンク用の最小限のリンク風ボタンスタイル。
             IdeaNest専用リソースは参照せず、既存の汎用DynamicResourceだけを使う。
             下線＋アクセント色＋ホバー/フォーカス背景で、色だけに依存しない。 -->
        <Style x:Key="ContinueFromLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBg}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- AT-5: 初回相当の空状態でだけ表示する一行ガイド。常設バー・ダイアログ・画像は使わない -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="まずはここへ書き出せます。他のWorkspaceは上の「＋」から始められます。"
                   Foreground="{DynamicResource MutedFg}"
                   FontSize="12"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   IsHitTestVisible="False"
                   AutomationProperties.AutomationId="TempNest.GettingStartedHint"
                   AutomationProperties.Name="まずはここへ書き出せます。他のWorkspaceは上の「＋」から始められます。"
                   Visibility="{Binding ShouldShowGettingStartedHint, Converter={StaticResource BoolToVis}}"/>

        <!-- SH-40 (AT-1 フェーズ1): 通常タブの復元・作成が一切なかった起動時だけ、
             recent files上位3件と保持中draft件数を表示する。AT-5とは同一領域で排他表示
             （ShouldShowContinueFrom/ShouldShowGettingStartedHintが互いに排他になるよう
             TempNestWorkspaceViewModel側で調整済み）。専用パネル・閉じる操作・手動再表示は持たない。 -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                    Margin="0,0,0,8"
                    AutomationProperties.AutomationId="TempNest.ContinueFrom"
                    Visibility="{Binding ShouldShowContinueFrom, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding RetainedDraftCountMessage}"
                       Foreground="{DynamicResource MutedFg}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       IsHitTestVisible="False"
                       AutomationProperties.AutomationId="TempNest.ContinueFrom.DraftHint"
                       AutomationProperties.Name="{Binding RetainedDraftCountMessage}"
                       Visibility="{Binding HasRetainedDraftCandidates, Converter={StaticResource BoolToVis}}"/>
            <WrapPanel Orientation="Horizontal"
                       Visibility="{Binding HasRecentContinueItems, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="続きから: "
                           Foreground="{DynamicResource MutedFg}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
                <ItemsControl ItemsSource="{Binding RecentContinueItems}"
                              AutomationProperties.AutomationId="TempNest.ContinueFrom.RecentList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LeadingSeparator}"
                                           Foreground="{DynamicResource MutedFg}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <Button Command="{Binding OpenCommand}"
                                        ToolTip="{Binding FilePath}"
                                        Style="{StaticResource ContinueFromLinkButtonStyle}"
                                        AutomationProperties.Name="{Binding AutomationName}"
                                        AutomationProperties.AutomationId="{Binding AutomationId}">
                                    <TextBlock Text="{Binding FileName}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </StackPanel>

        <!-- Slot 1: Top-Left -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"
                CornerRadius="4" Background="{DynamicResource SidebarBg}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,6,0,0">
                    <TextBlock Text="{Binding Slot1.FeedbackMessage}"
                               Foreground="{DynamicResource MutedFg}"
                               FontSize="10.5"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding Slot1.HasFeedback, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="コピー" Padding="8,3" Margin="0,0,4,0" FontSize="11"
                            AutomationProperties.AutomationId="TempNest.Slot1.CopyButton"
                            AutomationProperties.Name="TempNest.Slot1.CopyButton"
                            Command="{Binding Slot1.CopyBodyCommand}"
                            Background="Transparent" BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"/>
                    <Button Content="クリア" Padding="8,3" Margin="0,0,4,0" FontSize="11"
                            AutomationProperties.AutomationId="TempNest.Slot1.ClearButton"
                            AutomationProperties.Name="TempNest.Slot1.ClearButton"
                            Command="{Binding Slot1.ClearCommand}"
                            Background="Transparent" BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"/>
                    <Button Content="NoteNestへ昇格" Padding="8,3" FontSize="11"
                            AutomationProperties.AutomationId="TempNest.Slot1.PromoteButton"
                            AutomationProperties.Name="TempNest.Slot1.PromoteButton"
                            ToolTip="スロットの本文を新規NoteNestノートへ転送します"
                            Command="{Binding Slot1.PromoteToNoteCommand}"
                            Background="Transparent" BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"/>
                </StackPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBox Text="{Binding Slot1.Title, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="TempNest.Slot1.TitleBox"
                             AutomationProperties.Name="TempNest.Slot1.TitleBox"
                             BorderThickness="0,0,0,1" BorderBrush="{DynamicResource PaneBorder}"
                             Background="Transparent" Foreground="{DynamicResource AppFg}"
                             FontFamily="{Binding ContentFontFamily}" FontSize="12" FontWeight="SemiBold" Padding="0,0,0,4"
                             MaxLength="100"/>
                    <TextBlock Text="タイトル"
                               Foreground="{DynamicResource MutedFg}"
                               FontSize="12" FontWeight="SemiBold"
                               Padding="1,0,0,0" VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Slot1.Title}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Grid>
                    <TextBox Text="{Binding Slot1.Body, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="TempNest.Slot1.BodyBox"
                             AutomationProperties.Name="TempNest.Slot1.BodyBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource AppFg}"
                             VerticalContentAlignment="Top" FontFamily="{Binding ContentFontFamily}" FontSize="12" Padding="0"
                             SpellCheck.IsEnabled="False"/>
                    <TextBlock Text="一時メモ"
                               Foreground="{DynamicResource MutedFg}"
                               FontSize="12"
                               Padding="1,0,0,0" VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Slot1.Body}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

