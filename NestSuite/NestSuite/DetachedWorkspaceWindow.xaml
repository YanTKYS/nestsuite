<Window x:Class="NestSuite.DetachedWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NestSuite"
        Height="600" Width="900"
        MinHeight="300" MinWidth="870"
        WindowStartupLocation="CenterOwner">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="CommandSave_Executed"/>
    </Window.CommandBindings>
    <DockPanel>
        <!-- v2.16.5 SH-28: 保存・エクスポート等の完了を伝える一時通知。AppShell 側と同じ表示方針。 -->
        <Border DockPanel.Dock="Bottom" Height="22"
                Background="{DynamicResource StatusBarBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="DetachedStatusText"
                       Margin="10,0" VerticalAlignment="Center"
                       FontSize="11" Foreground="{DynamicResource MutedFg}"/>
        </Border>
        <Grid x:Name="WorkspaceHost"/>
    </DockPanel>
</Window>
